generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Registration {
  id        String   @id @default(uuid())

  group     String
  district  String
  location  String?
  status    String

  fullName  String
  gender    String
  phone     String   @unique
  email     String?

  createdAt DateTime @default(now())

  altarCalls AltarCall[]
}

model AltarCall {
  id             String   @id @default(uuid())

  phone          String
  fullName       String
  district       String?
  location       String?
  isFirstTimer   Boolean?

  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id])

  createdAt      DateTime @default(now())

  @@index([phone])
}
